extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Detalhes do Registo

    .w3-container
      p.w3-small Atualizado: #{date}

      .w3-row-padding
        .w3-half
          .w3-card.w3-margin-bottom
            .w3-container
              h4 Cliente
              p
                b ID:
                |  #{repair._id}
              p
                b Nome:
                |  #{repair.nome}
              p
                b NIF:
                |  #{repair.nif}
              p
                b Data:
                |  #{repair.data}

        .w3-half
          .w3-card.w3-margin-bottom
            .w3-container
              h4 Viatura
              p
                b Marca:
                |  
                a(href='/' + repair.viatura.marca) #{repair.viatura.marca}
              p
                b Modelo:
                |  #{repair.viatura.modelo}
              p
                b Matrícula:
                |  #{repair.viatura.matricula}

      h4 Intervenções (#{repair.nr_intervencoes})
      table.w3-table-all.w3-hoverable.w3-margin-top
        tr
          th Código
          th Nome
          th Descrição

        each i in repair.intervencoes
          tr
            td #{i.codigo}
            td #{i.nome}
            td #{i.descricao}

      a.w3-btn.w3-grey.w3-margin-top(href='/') Voltar
